    {
      "id": 23,
      "title": "전체 스택 메모리 사용량 (MiB 합산)",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 15, "w": 8, "h": 6 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "QuestDB" },
      "fieldConfig": {
        "defaults": {
          "unit": "mebibytes",
