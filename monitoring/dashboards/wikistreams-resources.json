{
  "uid": "wikistreams-resources",
  "title": "Resources Monitor",
  "tags": ["wikistreams"],
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-3h", "to": "now" },
  "schemaVersion": 38,
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "현재 리소스 사용량",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 2,
      "title": "CPU 사용률 (최근 2분 평균, 컨테이너별)",
      "type": "bargauge",
      "gridPos": { "x": 0, "y": 1, "w": 12, "h": 6 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "QuestDB" },
      "options": {
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "displayMode": "gradient"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 20 },
              { "color": "red", "value": 50 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT container, avg(cpu_pct) as cpu_pct FROM resource_metrics WHERE ts > dateadd('m', -2, now()) GROUP BY container ORDER BY container",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "메모리 사용률 (최근 2분 평균, 컨테이너별)",
      "type": "bargauge",
      "gridPos": { "x": 12, "y": 1, "w": 12, "h": 6 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "QuestDB" },
      "options": {
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "displayMode": "gradient"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 85 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT container, avg(mem_pct) as mem_pct FROM resource_metrics WHERE ts > dateadd('m', -2, now()) GROUP BY container ORDER BY container",
          "refId": "A"
        }
      ]
    },
    {
      "id": 10,
      "type": "row",
      "title": "CPU 추이",
      "gridPos": { "x": 0, "y": 7, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 11,
      "title": "producer CPU (%)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 8, "h": 6 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "QuestDB" },
      "fieldConfig": {
        "defaults": { "unit": "percent", "min": 0 },
        "overrides": []
      },
      "targets": [
        {
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT ts, avg(cpu_pct) as \"producer\" FROM resource_metrics WHERE $__timeFilter(ts) AND container = 'producer' SAMPLE BY 1m FILL(NULL)",
          "refId": "A"
        }
      ]
    },
    {
